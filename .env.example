# LLM Provider Configuration
# For free deployment, use "huggingface"
LLM_PROVIDER=huggingface

# Hugging Face API Token (get from https://huggingface.co/settings/tokens)
HF_API_TOKEN=your_huggingface_token_here

# Hugging Face Model (free options: google/flan-t5-base, facebook/bart-large-cnn)
HF_MODEL=google/flan-t5-base

# Optional: for Ollama deployment instead
# LLM_PROVIDER=ollama
# OLLAMA_HOST=http://localhost:11434
